# Опционально — для расширенной аналитики
FRED_API_KEY=
GLASSNODE_API_KEY=
COINGLASS_API_KEY=

# TTL кэша (секунды): быстрый блок — цена, funding/OI, MA200, Fear&Greed; медленный — макро, ончейн, ETF
CACHE_TTL=300
CACHE_TTL_FAST=
CACHE_TTL_SLOW=3600

# CoinGecko — третий fallback ончейна (proxy §8.10)
USE_COINGECKO_ONCHAIN=true
COINGECKO_ONCHAIN_CONFIDENCE=0.55
COINGECKO_ONCHAIN_SOURCE_SCORE=0.52

# LookIntoBitcoin — кэш (86400), выходные 2x
LOOKINTOBITCOIN_CACHE_TTL=86400
# Circuit breaker: отключить на N часов после M неудач
LOOKINTOBITCOIN_FAIL_LIMIT=5
LOOKINTOBITCOIN_DISABLE_HOURS=6
# Стабильность: max_delta для защиты от скачков
LOOKINTOBITCOIN_MAX_DELTA_MVRV=0.5
LOOKINTOBITCOIN_MAX_DELTA_NUPL=0.1
LOOKINTOBITCOIN_MAX_DELTA_SOPR=0.1
# Freshness, source_score
LOOKINTOBITCOIN_MAX_AGE_HOURS=24
LOOKINTOBITCOIN_SOURCE_SCORE_THRESHOLD=0.4
# Feature flags
USE_LOOKINTOBITCOIN=true
# USE_SELENIUM=false — ускорит загрузку (парсинг LookIntoBitcoin без Chrome)
USE_SELENIUM=true
# SQLite storage
BITTREND_DB_PATH=
