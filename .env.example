# Опционально — для расширенной аналитики
FRED_API_KEY=
GLASSNODE_API_KEY=
COINGLASS_API_KEY=

# Путь к YAML со весами скорера, порогам score→signal, аллокации и весам CoinGecko composite (E2).
# По умолчанию: bit_trend/config/scoring.yaml в установленном пакете.
# BITTREND_SCORING_CONFIG=

# HTTP ко всем внешним API (bit_trend.data.http_client): интервал по хосту, ретраи, backoff
HTTP_RATE_MIN_INTERVAL_SEC=0.12
HTTP_MAX_RETRIES=3
HTTP_BACKOFF_BASE_SEC=0.85
HTTP_BACKOFF_MAX_SEC=32
# Опционально: список кодов для повтора, через запятую (по умолчанию 429,500,502,503,504)
# HTTP_RETRY_STATUS=

# TTL кэша (секунды): быстрый блок — цена, funding/OI, MA200, Fear&Greed; медленный — макро, ончейн, ETF, §8.10 proxy
# CACHE_TTL передаётся в DataFetcher как базовый TTL быстрого блока; пустой CACHE_TTL_FAST = то же, что CACHE_TTL
CACHE_TTL=300
CACHE_TTL_FAST=
CACHE_TTL_SLOW=3600

# CoinGecko — третий fallback ончейна (proxy §8.10) + S1 composite/volatility/drawdown
USE_COINGECKO_ONCHAIN=true
COINGECKO_ONCHAIN_CONFIDENCE=0.55
COINGECKO_ONCHAIN_SOURCE_SCORE=0.52
# Кэш одного HTTP market_chart между fallback ончейна и fetcher (сек)
COINGECKO_BUNDLE_CACHE_SEC=120
# Ниже — необязательные переопределения чисел из scoring.yaml (приоритет над YAML).
# Веса composite_onchain (z-сумма); W_VOLATILITY обычно отрицательный
COMPOSITE_810_W_MVRV=0.30
COMPOSITE_810_W_NUPL=0.25
COMPOSITE_810_W_SOPR=0.20
COMPOSITE_810_W_DRAWDOWN=0.25
COMPOSITE_810_W_VOLATILITY=-0.10
COMPOSITE_810_Z_WINDOW=365
COMPOSITE_810_Z_MIN_PERIODS=30
# Опционально смешивать composite в BitTrendScorer (0 = только UI, см. upgrade_plan S1)
SCORER_WEIGHT_COMPOSITE_810=0
SCORER_COMPOSITE_810_SCALE=40

# LookIntoBitcoin — кэш (86400), выходные 2x
LOOKINTOBITCOIN_CACHE_TTL=86400
# Circuit breaker: отключить на N часов после M неудач
LOOKINTOBITCOIN_FAIL_LIMIT=5
LOOKINTOBITCOIN_DISABLE_HOURS=6
# Стабильность: max_delta для защиты от скачков
LOOKINTOBITCOIN_MAX_DELTA_MVRV=0.5
LOOKINTOBITCOIN_MAX_DELTA_NUPL=0.1
LOOKINTOBITCOIN_MAX_DELTA_SOPR=0.1
# Freshness, source_score
LOOKINTOBITCOIN_MAX_AGE_HOURS=24
LOOKINTOBITCOIN_SOURCE_SCORE_THRESHOLD=0.4
# Feature flags
USE_LOOKINTOBITCOIN=true
# USE_SELENIUM=false — ускорит загрузку (парсинг LookIntoBitcoin без Chrome)
USE_SELENIUM=true
# SQLite storage
BITTREND_DB_PATH=
